Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(?:app|bin|database|deploy|docs|routes|storage|tests|vendor)(?:/|$) - [F,L,NC]
    RewriteRule (^|/)\.(?!well-known/) - [F,L]

    RewriteRule ^assets/(.*)$ public/assets/$1 [L]
    RewriteRule ^sw\.js$ public/sw.js [L]
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<FilesMatch "(^\.env|composer\.(json|lock)|CODEX_PROMPT|Maison_Bebe_.*\.pdf|stripe\.txt|\.sql$)">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
</IfModule>

